{
  "name": "schemesense-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n FRONTEND,RAG-API -c cyan,magenta \"vite\" \"uvicorn --app-dir backend main:app --host 0.0.0.0 --port 8001\"",
    "dev:frontend": "vite",
    "dev:backend": "uvicorn --app-dir backend main:app --host 0.0.0.0 --port 8001 --reload --reload-dir backend",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "d3-scale": "^4.0.2",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-joyride": "^3.2.0",
    "react-simple-maps": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
